# Edict API 配置
EDICT_API_URL=http://localhost:8000
EDICT_WS_URL=ws://localhost:8000

# API 超时配置（秒）
EDICT_API_TIMEOUT=30

# 最大重试次数
EDICT_MAX_RETRIES=3

# WebSocket 重连延迟（秒）
EDICT_WS_RECONNECT_DELAY=5

# WebSocket 心跳间隔（秒）
EDICT_WS_HEARTBEAT_INTERVAL=30

# MCP Server 配置
MCP_SERVER_NAME=edict
MCP_SERVER_VERSION=0.1.0

# 日志级别
LOG_LEVEL=INFO
